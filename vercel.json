{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/blog/", "destination": "/blog", "permanent": true },
    { "source": "/blog/category/:cat/", "destination": "/blog/category/:cat", "permanent": true },
    { "source": "/categories/spices-staples", "destination": "/categories/spices-ingredients", "permanent": true },
    { "source": "/categories/fashion-fabric", "destination": "/categories/fashion-fabrics", "permanent": true },
    { "source": "/categories/drinks", "destination": "/categories/drinks-beverages", "permanent": true },
    { "source": "/categories/halal", "destination": "/categories/halal-products", "permanent": true },
    { "source": "/categories/meat-and-fish", "destination": "/categories/meat-fish", "permanent": true },
    { "source": "/categories/rice-grains-flour", "destination": "/categories/staples-grains", "permanent": true },
    {
      "source": "/blog/top-caribbean-ingredients-cooking-home",
      "destination": "/blog/essential-caribbean-ingredients-order-online",
      "permanent": true
    },
    {
      "source": "/blog/caribbean-cooking-essential-ingredients-buy-online",
      "destination": "/blog/essential-caribbean-ingredients-order-online",
      "permanent": true
    },
    {
      "source": "/blog/caribbean-cooking-ingredients-guide",
      "destination": "/blog/essential-caribbean-ingredients-order-online",
      "permanent": true
    },
    {
      "source": "/blog/best-african-grocery-stores-manchester",
      "destination": "/blog/guide-african-caribbean-asian-stores-manchester",
      "permanent": true
    },
    {
      "source": "/blog/african-caribbean-grocery-stores-manchester",
      "destination": "/blog/guide-african-caribbean-asian-stores-manchester",
      "permanent": true
    },
    {
      "source": "/blog/halal-meat-online-birmingham",
      "destination": "/blog/guide-african-caribbean-asian-stores-manchester",
      "permanent": true
    },
    {
      "source": "/blog/halal-meat-online-uk-guide",
      "destination": "/blog/guide-african-caribbean-asian-stores-manchester",
      "permanent": true
    },
    {
      "source": "/blog/why-i-built-clip-services-founder-story",
      "destination": "/blog",
      "permanent": true
    },
    { "source": "/blog/rss", "destination": "/blog/feed", "permanent": false }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/blog/rss.xml", "destination": "/api/blog-rss" },
    { "source": "/blog/feed/", "destination": "/api/blog-rss-landing" },
    { "source": "/blog/feed", "destination": "/api/blog-rss-landing" },
    { "source": "/blog/category/:cat", "destination": "/api/blog-html?blogCategory=:cat" },
    { "source": "/blog/:slug", "destination": "/api/blog-html?slug=:slug" },
    { "source": "/blog", "destination": "/api/blog-html" },
    { "source": "/blog/", "destination": "/api/blog-html" },
    { "source": "/community/:slug", "destination": "/api/community-html?slug=:slug" },
    { "source": "/products/:slug", "destination": "/api/product-seo-html?slug=:slug" },
    { "source": "/search/:slug", "destination": "/search/index.html?landing=:slug" },
    { "source": "/search", "destination": "/search/index.html" },
    { "source": "/search/", "destination": "/search/index.html" },
    { "source": "/stores/:slug", "destination": "/api/store-html?slug=:slug" },
    { "source": "/store/:sid/p/:idx/:slug", "destination": "/api/product-html?storeId=:sid&idx=:idx" },
    { "source": "/store/:id", "destination": "/api/store-html?id=:id" },
    { "source": "/cities/:city", "destination": "/api/city-html?city=:city" },
    { "source": "/categories/:slug", "destination": "/api/category-html?slug=:slug" },
    { "source": "/", "destination": "/clip-services-marketplace" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/admin/blog", "destination": "/admin/blog/index.html" },
    { "source": "/admin/blog/", "destination": "/admin/blog/index.html" },
    { "source": "/provider", "destination": "/provider/index.html" },
    { "source": "/provider/", "destination": "/provider/index.html" },
    { "source": "/user", "destination": "/user/index.html" },
    { "source": "/user/", "destination": "/user/index.html" },
    { "source": "/account", "destination": "/account/index.html" },
    { "source": "/account/", "destination": "/account/index.html" },
    { "source": "/stores", "destination": "/stores/index.html" },
    { "source": "/stores/", "destination": "/stores/index.html" },
    { "source": "/store-owner/dashboard", "destination": "/store-owner/dashboard/index.html" },
    { "source": "/store-owner/dashboard/", "destination": "/store-owner/dashboard/index.html" },
    { "source": "/store-owner/apply", "destination": "/store-owner/apply/index.html" },
    { "source": "/store-owner/apply/", "destination": "/store-owner/apply/index.html" },
    { "source": "/market-stall/apply", "destination": "/market-stall/apply/index.html" },
    { "source": "/market-stall/apply/", "destination": "/market-stall/apply/index.html" },
    { "source": "/apply/confirmed", "destination": "/apply/confirmed/index.html" },
    { "source": "/apply/confirmed/", "destination": "/apply/confirmed/index.html" },
    { "source": "/store-owner", "destination": "/store-owner/index.html" },
    { "source": "/store-owner/", "destination": "/store-owner/index.html" },
    { "source": "/market-stall", "destination": "/market-stall/index.html" },
    { "source": "/market-stall/", "destination": "/market-stall/index.html" },
    { "source": "/market-stalls", "destination": "/market-stalls/index.html" },
    { "source": "/market-stalls/", "destination": "/market-stalls/index.html" },
    { "source": "/impact", "destination": "/impact/index.html" },
    { "source": "/impact/", "destination": "/impact/index.html" },
    { "source": "/customer/orders", "destination": "/customer/orders/index.html" },
    { "source": "/customer/orders/", "destination": "/customer/orders/index.html" },
    { "source": "/customer/order-confirmed", "destination": "/customer/order-confirmed/index.html" },
    { "source": "/customer/order-confirmed/", "destination": "/customer/order-confirmed/index.html" },
    { "source": "/customer/review", "destination": "/customer/review/index.html" },
    { "source": "/customer/review/", "destination": "/customer/review/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/about/", "destination": "/about/index.html" }
  ],
  "crons": [
    {
      "path": "/api/whatsapp-cron",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/[...path].js": { "maxDuration": 60 },
    "api/admin/index.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=7200" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *;"
        },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/provider",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/provider/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/account",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/account/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/store-owner/dashboard",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/store-owner/dashboard/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, must-revalidate, max-age=0" }
      ]
    }
  ]
}
